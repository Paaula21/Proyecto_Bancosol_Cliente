<file path="html/EditarCampana.html">
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../css/Administrador.css">
    <link rel="stylesheet" href="../css/EditarCampana.css">
    <link rel="stylesheet" href="../css/popUpRegistro.css">

    <script src="../javascript/IncludeHTML.js"></script>
    <script src="../javascript/Sidebar.js" defer></script>
    <script src="../javascript/EditarCampana.js" defer></script>
    <title>Editar Campaña</title>
</head>

<body>
    <div class="main-container">
        <!-- Barra lateral -->
        <aside class="sidebar">
            <include-html src="../html/Sidebar.html"></include-html>
        </aside>

        <div class="right-container">
            <header class="header-dashboard">
                <img src="../images/icono.png" alt="App Icon" class="header-logo">
                <div class="header-titles">
                    <h1>Edición de Campaña</h1>
                    <p>Modifique los detalles generales y las cadenas participantes</p>
                </div>
                <div class="header-actions">
                    <button class="notification-btn" title="Notificaciones">
                        <p>N</p>
                    </button>
                </div>
            </header>

            <div class="form-container">
                <form action="#" method="POST" class="form-edit" id="form-edit">

                    <div class="form-card">
                        <fieldset>
                            <legend>Datos de la campaña</legend>

                            <div class="form-group">
                                <label for="name-campanya">Nombre de la campaña</label>
                                <input type="text" id="name-campanya" name="name-campanya" value="Campaña Verano 2024"
                                    required>
                            </div>

                            <div class="form-group">
                                <label for="initial-date">Fecha de Inicio</label>
                                <input type="date" id="initial-date" name="initial-date" value="2024-05-15" required>
                            </div>

                            <div class="form-group">
                                <label for="final-date">Fecha de Finalización</label>
                                <input type="date" id="final-date" name="final-date" value="2024-08-20" required>
                            </div>

                            <div class="form-group">
                                <label for="status">Estado actual</label>
                                <select id="status" name="status" required>
                                    <option value="Planificada">Planificada</option>
                                    <option value="Activa" selected>Activa</option>
                                    <option value="Completada">Completada</option>
                                    <option value="Finalizada">Finalizada</option>
                                    <option value="Cancelada">Cancelada</option>
                                </select>
                            </div>
                        </fieldset>

                        <div class="form-actions">
                            <button type="submit" class="btn-submit">Guardar Cambios</button>
                            <button type="button" class="btn-cancel" id="btn-cancelar">Cancelar</button>
                        </div>
                    </div>

                    <div class="form-card">
                        <fieldset>
                            <legend>Cadenas Participantes</legend>
                            <p class="checkbox-section-title">Seleccione las cadenas que forman parte de esta campaña:
                            </p>

                            <div class="checkbox-list" id="checkbox-list">
                                <!-- Se rellena desde JS -->
                            </div>
                        </fieldset>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <div class="overlay" id="overlay-confirmar">
        <div class="popup" id="popup-confirmar">
            <h3>¿Confirmar cambios?</h3>
            <p>¿Estás seguro de que deseas guardar los cambios realizados en esta campaña?</p>
            <div class="popup-actions">
                <button type="button" class="btn-add" id="btn-confirmar-edicion">Confirmar</button>
                <button type="button" class="btn-cerrar-popup" id="btn-cancelar-edicion">Cancelar</button>
            </div>
        </div>
    </div>

    <div class="overlay" id="overlay-descartar">
        <div class="popup" id="popup-descartar">
            <h3>¿Quiere descartar los cambios?</h3>
            <p>Perderá todos los cambios no guardados.</p>
            <div class="popup-actions">
                <button type="button" class="btn-add" id="btn-confirmar-descarte">Sí</button>
                <button type="button" class="btn-cerrar-popup" id="btn-cancelar-descarte">No</button>
            </div>
        </div>
    </div>
</body>

</html>
</file>

