<file path="css/Administrador.css">
* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f5f7f9;
    color: #111827;
}

.main-container {
    display: flex;
    height: 100vh;
    width: 100%;
    overflow: hidden;
}

.right-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}

.header-dashboard {
    background-color: #ffffff;
    padding: 16px 32px;
    gap: 15px;
    display: flex;
    align-items: center;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}

.header-titles h1 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
}

.header-titles p {
    margin: 4px 0 0 0;
    font-size: 0.875rem;
    color: #6b7280;
}

.header-logo {
    height: 50px;
}

.header-actions {
    margin-left: auto;
    display: flex;
    align-items: end;
    gap: 16px;
}

.notification-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid #d1d5db;
    background-color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #374151;
    font-weight: bold;
}

.dashboard-container {
    padding: 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
}

.grid > .card {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
}

.grid > .card h3 {
    margin: 0 0 12px 0;
    font-size: 0.875rem;
    color: #6b7280;
    font-weight: normal;
}

.grid > .card > div.card {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    border: none;
    padding: 0;
    box-shadow: none;
    margin-bottom: 4px;
}

.grid > .card > p.card {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7280;
}

/* grid-template-columns para no usar hijos*/
.dashboard-middle {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
}

.upcoming-campaigns, 
.zone-coverage, 
.recent-activity-container {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
}

.header-upcoming-campaigns, 
.panel-header, 
.header-recent-activity {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.header-upcoming-campaigns h2, 
.panel-header h2, 
.header-recent-activity h2 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
}

.header-upcoming-campaigns p, 
.panel-header p, 
.header-recent-activity p {
    margin: 4px 0 0 0;
    font-size: 0.875rem;
    color: #6b7280;
}

.btn-view-all {
    padding: 10px 12px;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #420098;
    color: #ffffff;
}

.btn-view-all:hover {
    background-color: #310073;
}

.campaign-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.campaign-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
}

.campaign-info h4 {
    margin: 0 0 4px 0;
    font-size: 1rem;
    color: #111827;
}

.campaign-info span {
    font-size: 0.875rem;
    color: #6b7280;
}

.campaign-stats {
    display: flex;
    gap: 24px;
}

.stat {
    font-size: 0.875rem;
    color: #6b7280;
    display: flex;
    flex-direction: column;
    text-align: center;
}

.stat strong {
    color: #111827;
    font-size: 1rem;
}

.shops-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
}

.shops-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.shop-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: #374151;
}

.shop-labels p {
    margin: 0;
}

.progress-bar-container {
    width: 100%;
    background-color: #e5e7eb;
    height: 8px;
    border-radius: 4px;
    overflow: hidden;
}

.progress-bar {
    height: 100%;
    background-color: #420098;
    border-radius: 4px;
}

.activity-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    margin-top: 10px;
}

.activity-table th {
    padding: 12px 16px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    border-bottom: 1px solid #e5e7eb;
}

.activity-table td {
    padding: 16px;
    font-size: 0.875rem;
    color: #374151;
    border-bottom: 1px solid #f3f4f6;
    vertical-align: middle;
}
</file>

