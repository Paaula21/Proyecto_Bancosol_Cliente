<file path="javascript/EditarColaborador.js">
const API_BASE = 'http://localhost:3000';
const idURL = new URLSearchParams(window.location.search).get('id');

document.addEventListener("DOMContentLoaded", async () => {
    const resColab = await fetch(`${API_BASE}/colaborador/${idURL}`);
    const colab = await resColab.json();
    
    document.getElementById('nombre').value = colab.nombre_colaborador;
    document.getElementById('cod').value = colab.id_colaborador;

    const resZonas = await fetch(`${API_BASE}/zona_geografica`);
    const zonas = await resZonas.json();
    const selectZona = document.getElementById('zona');
    zonas.forEach(z => {
        const opt = document.createElement('option');
        opt.value = z.id_zona; opt.textContent = z.nombre_zona;
        selectZona.appendChild(opt);
    });
});

document.getElementById('form-edit-colab').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const res = await fetch(`${API_BASE}/colaborador/${idURL}`, {
        method: 'PATCH',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
            nombre_colaborador: document.getElementById('nombre').value
        })
    });

    if (res.ok) window.location.href = 'Colaboradores.html';
});
</file>

<file path="javascript/NuevoColaborador.js">
const API_BASE = 'http://localhost:3000';

document.addEventListener("DOMContentLoaded", async () => {
    // Cargar zonas para el select
    const resZonas = await fetch(`${API_BASE}/zona_geografica`);
    const zonas = await resZonas.json();
    const selectZona = document.getElementById('id_zona');
    zonas.forEach(z => {
        const opt = document.createElement('option');
        opt.value = z.id_zona;
        opt.textContent = z.nombre_zona;
        selectZona.appendChild(opt);
    });
});

document.getElementById('form-nuevo-colab').addEventListener('submit', async (e) => {
    e.preventDefault();

    // 1. Crear la dirección primero (necesitamos el id_direccion)
    const nuevaDir = {
        tipo_via: document.getElementById('tipo_via').value,
        nombre_via: document.getElementById('nombre_via').value,
        numero: null,
        id_cp: 1 // Simplificado para el ejemplo
    };

    const resDir = await fetch(`${API_BASE}/direccion`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(nuevaDir)
    });
    const dirGuardada = await resDir.json();

    // 2. Crear el colaborador vinculado a esa dirección
    const nuevoColab = {
        id_colaborador: document.getElementById('id_colaborador').value,
        nombre_colaborador: document.getElementById('nombre').value,
        observaciones: null,
        id_direccion: dirGuardada.id
    };

    const resColab = await fetch(`${API_BASE}/colaborador`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(nuevoColab)
    });

    if (resColab.ok) {
        alert("Colaborador creado con éxito");
        window.location.href = 'Colaboradores.html';
    }
});
</file>

