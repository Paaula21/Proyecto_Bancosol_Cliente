<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nuevo Establecimiento</title>
    <link rel="stylesheet" href="../css/InformacionTienda.css">
    <link rel="stylesheet" href="../css/Sidebar.css">
    <link rel="stylesheet" href="../css/Common.css">
    <link rel="stylesheet" href="../css/popUpRegistro.css">
    <link rel="stylesheet" href="../css/DetalleColaborador.css">
    <link rel="stylesheet" href="../css/EditarColaborador.css">
    <script src="../javascript/IncludeHTML.js"></script>
    <script src="../javascript/NuevaTienda.js"></script>
    <script src="../javascript/Sidebar.js" defer></script>
</head>
<body>
<div class="app-container">
    <aside class="sidebar">
        <include-html src="../html/Sidebar.html"></include-html>
    </aside>
    <div class="right-content">
        <header class="main-header">
            <nav>
                <div class="header-branding">
                    <img src="../images/icono.png" alt="Bancosol" class="header-logo">
                    <div class="header-titles">
                        <h1>Nuevo Establecimiento</h1>
                        <p>Añadir un nuevo establecimiento a la base de datos</p>
                    </div>
                </div>
                <a href="InformacionTienda.html">
                    <button class="btn btn--secondary">← Volver</button>
                </a>
            </nav>
        </header>

        <div class="main-layout">
            <main>
                <div class="content-wrapper">

                    <aside class="detail-panel">
                        <div class="detail-content">
                            <div id="formulario-nueva-tienda" class="datos-colaborador">
                                <h3 class="ficha-titulo-principal">Ficha del Establecimiento</h3>

                                <form id="form-nueva-tienda">

                                    <div class="ficha-tarjeta-info tarjeta-cabecera-edit">
                                        <h5>Nombre del Establecimiento</h5>
                                        <input type="text" id="nueva-nombre" class="input-ficha-lateral input-nombre-principal" required placeholder="Ej. Carrefour Hiper Centro">
                                    </div>

                                    <div class="ficha-tarjeta-info">
                                        <h5>Cadena</h5>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-cadena"><strong>Cadena comercial:</strong></label>
                                            <select id="nueva-cadena" class="select-ficha-lateral" required>
                                                <option value="">Selecciona una cadena...</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="ficha-tarjeta-info">
                                        <h5>Dirección Postal</h5>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-tipo-via"><strong>Tipo de Vía:</strong></label>
                                            <select id="nueva-tipo-via" class="select-ficha-lateral">
                                                <option value="">Selecciona...</option>
                                                <option value="Calle">Calle</option>
                                                <option value="Avenida">Avenida</option>
                                                <option value="Plaza">Plaza</option>
                                            </select>
                                        </div>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-via"><strong>Nombre de la Vía:</strong></label>
                                            <input type="text" id="nueva-via" class="input-ficha-lateral" placeholder="Ej. Av. de Andalucía">
                                        </div>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-numero"><strong>Número:</strong></label>
                                            <input type="text" id="nueva-numero" class="input-ficha-lateral" placeholder="Ej. 12">
                                        </div>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-cp"><strong>Código Postal:</strong></label>
                                            <select id="nueva-cp" class="select-ficha-lateral" required>
                                                <option value="">Selecciona un CP...</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="ficha-tarjeta-info">
                                        <h5>Información General</h5>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-lineales"><strong>Número de cajas:</strong></label>
                                            <input type="number" id="nueva-lineales" class="input-ficha-lateral" placeholder="Número de lineales" min="0">
                                        </div>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-coordinador"><strong>Coordinador:</strong></label>
                                            <select id="nueva-coordinador" class="select-ficha-lateral">
                                                <option value="">Sin asignar</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="ficha-tarjeta-info">
                                        <h5>Campañas</h5>
                                        <div class="campo-formulario-ficha">
                                            <label for="nueva-campanas"><strong>Participación en campañas:</strong></label>
                                            <select id="nueva-campanas" class="select-ficha-lateral" multiple size="4">
                                            </select>
                                            <small style="color:#6b7280; font-size:0.75rem; margin-top:4px;">Mantén Ctrl (o Cmd en Mac) para seleccionar varias</small>
                                        </div>
                                    </div>

                                </form>
                            </div>
                        </div>

                        <div class="detail-actions-sticky">
                            <button type="submit" form="form-nueva-tienda" id="btn-guardar-tienda" class="btn-ficha btn-guardar">Guardar</button>
                            <a href="InformacionTienda.html">
                                <button type="button" class="btn-ficha btn-cancelar-edit">Cancelar</button>
                            </a>
                        </div>
                    </aside>

                </div>
            </main>
        </div>
    </div>
</div>

<div class="overlay" id="overlay-exito">
    <div class="popup" id="popup-exito">
        <h3>¡Guardado con éxito!</h3>
        <p>El establecimiento ha sido añadido correctamente a la base de datos.</p>
        <div class="popup-actions">
            <form action="">
                <button class="btn-add" id="btn-aceptar-exito">Aceptar</button>
            </form>
        </div>
    </div>
</div>

<div class="overlay" id="overlay-error">
    <div class="popup" id="popup-error">
        <h3>Ha ocurrido un error</h3>
        <p id="texto-error-popup">No se pudo guardar el establecimiento.</p>
        <div class="popup-actions">
            <form action="">
                <button class="btn-cerrar-popup" id="btn-aceptar-error">Aceptar</button>
            </form>
        </div>
    </div>
</div>

</body>
</html>
