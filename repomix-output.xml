}

.detail-actions-sticky .btn-ficha:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

/* ─── Select múltiple dentro del formulario ─── */
#form-campanas {
    min-height: 80px;
}

#form-campanas option {
    padding: 4px 6px;
}

#form-campanas option:checked {
