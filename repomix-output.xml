<file path="html/Administrador.html">
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../css/Administrador.css">
    <link rel="stylesheet" href="../css/Sidebar.css">
    <script src="../javascript/IncludeHTML.js"></script>
    <script src="../javascript/Sidebar.js" defer></script>
    <title>Dashboard - Vista de administrador</title>
</head>
<body>
    <div class="main-container">
        <aside class="sidebar">
            <include-html src="../html/Sidebar.html"></include-html>
        </aside>

        <div class="right-container">
            <header class="header-dashboard">
                <img src="../images/icono.png" alt="App Icon" class="header-logo">
                <div class="header-titles">
                    <h1>Dashboard</h1>
                    <p>Datos del sistema de gestión de campañas</p>
                </div>
                <div class="header-actions">
                    <button class="notification-btn">
                        <p>N</p>
                    </button>
                </div>
            </header>

            <main class="dashboard-container">
                
                <section class="grid">
                    <div class="card">
                        <h3>Campañas Activas</h3>
                        <div class="card">2</div>
                        <p class="card">Gran Recogida, Primavera</p>
                    </div>
                    <div class="card">
                        <h3>Tiendas Totales</h3>
                        <div class="card">267</div>
                        <p class="card">En 5 zonas geográficas</p>
                    </div>
                    <div class="card">
                        <h3>Colaboradores</h3>
                        <div class="card">156</div>
                        <p class="card">Entidades y voluntarios</p>
                    </div>
                    <div class="card">
                        <h3>Coordinadores</h3>
                        <div class="card">12</div>
                        <p class="card">Activos en campaña</p>
                    </div>
                </section>

                <section class="dashboard-middle">
                    <div class="upcoming-campaigns">
                        <div class="header-upcoming-campaigns">
                            <div>
                                <h2>Próximas Campañas</h2>
                                <p>Campañas programadas</p>
                            </div>
                            <button class="btn-view-all">Ver todas</button>
                        </div>
                        
                        <div class="campaign-container">
                            <div class="campaign-item">
                                <div class="campaign-info">
                                    <h4>Gran Recogida 2025</h4>
                                    <span>22-23 Nov 2025</span>
                                </div>
                                <div class="campaign-stats">
                                    <div class="stat"><strong>156</strong> Tiendas</div>
                                    <div class="stat"><strong>845</strong> Voluntarios</div>
                                </div>
                            </div>
                            <div class="campaign-item">
                                <div class="campaign-info">
                                    <h4>Campaña Primavera</h4>
                                    <span>15-16 Mar 2025</span>
                                </div>
                                <div class="campaign-stats">
                                    <div class="stat"><strong>120</strong> Tiendas</div>
                                    <div class="stat"><strong>620</strong> Voluntarios</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="zone-coverage panel">
                        <div class="panel-header">
                            <h2>Cobertura por Zona</h2>
                            <p>Número de tiendas por zona</p>
                        </div>
                        <!-- Para indicar el proceso de la barra se pone un style y se rellena más o menos -->
                        <div class="shops-list">
                            <div class="shops-item">
                                <div class="shop-labels">
                                    <span>Málaga Capital</span>
                                    <span>45 tiendas</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="width: 92%;"></div>
                                </div>
                            </div>
                            <div class="shops-item">
                                <div class="shop-labels">
                                    <span>Costa Occidental</span>
                                    <span>38 tiendas</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="width: 85%;"></div>
                                </div>
                            </div>
                            <div class="shops-item">
                                <div class="shop-labels">
                                    <span>Axarquía</span>
                                    <span>28 tiendas</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="width: 72%;"></div>
                                </div>
                            </div>
                            <div class="shops-item">
                                <div class="shop-labels">
                                    <span>Interior</span>
                                    <span>22 tiendas</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="width: 68%;"></div>
                                </div>
                            </div>
                            <div class="shops-item">
                                <div class="shop-labels">
                                    <span>Antequera</span>
                                    <span>12 tiendas</span>
                                </div>
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="width: 55%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="recent-activity-container">
                    <div class="header-recent-activity">
                        <div>
                            <h2>Actividad Reciente</h2>
                            <p>Últimas acciones realizadas en el sistema</p>
                        </div>
                        <button class="btn-view-all">Ver todo</button>
                    </div>
                    
                    <table class="activity-table">
                        <thead>
                            <tr>
                                <th>Acción</th>
                                <th>Descripción</th>
                                <th>Usuario</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Nueva asignación</td>
                                <td>Carrefour Hiper - Rincón de la Victoria</td>
                                <td>J.M. Cobos</td>
                                <td>Completado</td>
                            </tr>
                            <tr>
                                <td>Colaborador añadido</td>
                                <td>Ayuntamiento de Almachar</td>
                                <td>Arantxa</td>
                                <td>Pendiente</td>
                            </tr>
                            <tr>
                                <td>Tienda actualizada</td>
                                <td>Carrefour Express - Málaga</td>
                                <td>Fran Jiménez</td>
                                <td>Revisar</td>
                            </tr>
                            <tr>
                                <td>Campaña creada</td>
                                <td>Gran Recogida 2025</td>
                                <td>J.M. Cobos</td>
                                <td>Completado</td>
                            </tr>
                        </tbody>
                    </table>
                </section>

            </main>
        </div>
    </div>
</body>
</html>
</file>

