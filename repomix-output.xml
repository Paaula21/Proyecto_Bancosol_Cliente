<file path="html/Administrador.html">
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../css/Administrador.css">
    <link rel="stylesheet" href="../css/Sidebar.css">
    <script src="../javascript/IncludeHTML.js"></script>
    <script src="../javascript/Sidebar.js" defer></script>
    <script src="../javascript/Administrador.js" defer></script>
    <title>Dashboard - Vista de administrador</title>
</head>

<body>
    <div class="main-container">

        <aside class="sidebar">
            <include-html src="../html/Sidebar.html"></include-html>
        </aside>

        <div class="right-container">
            <header class="header-dashboard">
                <img src="../images/icono.png" alt="App Icon" class="header-logo">
                <div class="header-titles">
                    <h1>Dashboard</h1>
                    <p>Datos del sistema de gestión de campañas</p>
                </div>
                <div class="header-actions">
                    <button class="notification-btn">
                        <p>N</p>
                    </button>
                </div>
            </header>

            <main class="dashboard-container">
                <!-- TARJETAS DE RESUMEN -->
                <section class="grid">
                    <div class="card">
                        <h3>Campañas Activas</h3>
                        <div class="card" id="stat-campaigns-value"></div>
                        <p class="card" id="stat-campaigns-subtitle">Cargando...</p>
