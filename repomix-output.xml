/* ===================================================
   InformacionTienda.css
   Depende de: Common.css
   =================================================== */

/* ─── Layout principal ─── */
.main-layout {
    display: flex;
    flex: 1;
    overflow: hidden;
}

main {
    padding: 24px 32px;
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    background-color: #f5f7f9;
}

/* ─── Panel de filtros ─── */
.filters {
    background-color: #ffffff;
    border-radius: 8px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

/* Cada fila de filtros */
.filter-row {
    display: flex;
    gap: 12px;
    align-items: flex-end;
    flex-wrap: nowrap;
}

/* Campo base: ocupa espacio equitativo */
.filter-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 0;
    min-width: 0;
}

/* Tipo de Vía y Cód. Postal: más estrechos */
.filter-group--small {
    flex: 0 0 110px;
}

/* Calle: algo más ancho que el resto */
.filter-group--wide {
    flex: 1.5 1 0;
}

/* Columna del botón Filtrar: se ajusta al contenido */
.filter-group--btn {
    flex: 0 0 auto;
}

.filter-group--btn .btn {
    white-space: nowrap;
}

.filter-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
}

.filter-group select,
.filter-group input {
    padding: 6px 8px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.875rem;
    background-color: #ffffff;
    color: #374151;
    width: 100%;
    box-sizing: border-box;
}

.filter-group select:focus,
.filter-group input:focus {
    outline: none;
    border-color: #420098;
}

/* ─── Wrapper lista + panel de detalle ─── */
.content-wrapper {
    display: flex;
    gap: 24px;
    align-items: stretch;
    flex: 1;
    min-height: 0;
}

/* ─── Lista de establecimientos ─── */
.list-container {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    flex: 2;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.list-header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    margin-bottom: 24px;
}

.list-header h2 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
}

/* ─── Tabla ─── */

/* Balancear anchos de columna */
#tabla-establecimientos th:nth-child(1),
#tabla-establecimientos td:nth-child(1) {
    width: 15%;
}

#tabla-establecimientos th:nth-child(2),
#tabla-establecimientos td:nth-child(2) {
    width: 10%;
}

#tabla-establecimientos th:nth-child(3),
#tabla-establecimientos td:nth-child(3) {
    width: 10%;
}

/* Botones morados */
/* DESPUÉS */
td.col-actions .btn--secondary,
.content-wrapper .btn--secondary {
    background-color: #420098;
    color: white;
    border-color: transparent;
}

td.col-actions .btn--secondary:hover,
.content-wrapper .btn--secondary:hover {
    background-color: #310073;
}

td.col-actions .btn-icon--danger,
.content-wrapper .btn-icon--danger {
    background-color: transparent;
    border: 1.5px solid #e74c3c;
    color: #e74c3c;
    border-radius: 8px;
    padding: 8px 18px;
    font-weight: 600;
    font-size: 0.875rem;
    cursor: pointer;
    transition: background 0.2s;
}

td.col-actions .btn-icon--danger:hover,
.content-wrapper .btn-icon--danger:hover {
    background-color: #c0392b;
    border-color: #c0392b;
    color: #ffffff;
}

/* Wrapper con scroll horizontal siempre, vertical solo cuando JS lo activa */
.table-wrapper {
    overflow-x: auto;
    width: 100%;
    /* El JS añade la clase .scrollable cuando hay más de 4 filas visibles */
}

.table-wrapper.scrollable {
    max-height: 440px;
    overflow-y: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
}

thead {
    position: sticky;
    top: 0;
    z-index: 1;
    background-color: #f8fafc;
}

th {
    padding: 12px 16px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    border-bottom: 1px solid #e5e7eb;
}

td {
    padding: 16px;
    font-size: 0.875rem;
    color: #374151;
    border-bottom: 1px solid #f3f4f6;
    vertical-align: middle;
}

th.col-actions,
td.col-actions {
    text-align: right;
}

td.col-actions {
    text-align: right;
    white-space: nowrap;
    vertical-align: middle;
}

td.col-actions .btn {
    margin-left: 8px;
}
td.col-actions .btn:first-child {
    margin-left: 0;
}

/* Fila seleccionada */
tbody tr.selected {
    background-color: #f5f0ff;
}

/* Sin efecto hover en las filas */
tbody tr:hover {
    background-color: inherit;
    cursor: default;
}

/* ─── Panel de detalle lateral ─── */
.detail-panel {
